---
const {
  name,
  codepen_profile,
  github_profile,
  favorite_emoji,
  image,
  bio,
} = Astro.props;

const studentSlug = name.toLowerCase().replace(/\s+/g, "-");
---

<article class="card">
  <img src={image} alt={name} loading="lazy" />

  <div class="card-name">
    <span class="card-emoji" aria-hidden="true">{favorite_emoji}</span>
    <a href={`./${studentSlug}/`}>{name}</a>
  </div>

  <p>{bio}</p>

  <div class="card-links">
    <a href={codepen_profile} target="_blank" rel="noreferrer">CodePen</a>
    <a href={github_profile} target="_blank" rel="noreferrer">GitHub</a>
    <a href={`./${studentSlug}/`}>Student Page</a>
  </div>
</article>

<style>
  .card {
    border: 1px solid rgba(110, 123, 95, 0.25);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    background: rgba(255, 253, 248, 0.9);
    border-radius: var(--radius);
    box-shadow: var(--shadow);

    position: relative;
    overflow: hidden;

    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 36px rgba(78, 67, 57, 0.18);
  }

  .card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;

    border-radius: calc(var(--radius) - 0.45rem);
    border: 1px solid rgba(110, 123, 95, 0.2);
  }

  .card-name {
    font-family: "Quicksand", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .card-name a {
    color: var(--brown);
    text-decoration: none;
  }

  .card-name a:hover {
    color: var(--moss);
  }

  .card-emoji {
    display: inline-block;
    margin-right: 0.25rem;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .card-links a {
    text-decoration: none;
    color: var(--moss);
    background: var(--cream);
    border: 1px solid rgba(110, 123, 95, 0.25);
    border-radius: 999px;
    padding: 0.4rem 0.65rem;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .card-links a:hover {
    background: var(--moss);
    color: var(--soft-white);
  }
</style>